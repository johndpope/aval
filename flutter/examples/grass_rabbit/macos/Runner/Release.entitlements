<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox disabled so the app can dlopen() the aval_decode dylib from an
	     absolute path passed via --dart-define=AVAL_DECODE_LIB. See README. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
