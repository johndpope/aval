{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rendered-motion.dev/schemas/release-manifest.schema.json",
  "title": "Rendered Motion immutable release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "manifestKind", "releaseVersion", "candidateManifestDigest", "releaseSetDigest", "createdAt", "reports", "artifacts", "reviews", "previousKnownGood", "rollbackTag"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "manifestKind": { "const": "release" },
    "releaseVersion": { "const": "1.0.0" },
    "candidateManifestDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "releaseSetDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "createdAt": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$" },
    "reports": { "type": "array", "minItems": 1, "maxItems": 256, "items": { "$ref": "certification-attachment.schema.json" } },
    "artifacts": { "type": "array", "minItems": 1, "maxItems": 256, "items": { "$ref": "certification-attachment.schema.json" } },
    "reviews": { "type": "array", "minItems": 2, "maxItems": 32, "items": { "type": "object", "additionalProperties": false, "required": ["id", "decision", "evidenceDigest"], "properties": { "id": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$" }, "decision": { "const": "approved" }, "evidenceDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" } } } },
    "previousKnownGood": { "type": "string", "minLength": 1, "maxLength": 128 },
    "rollbackTag": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,63}$" }
  }
}
