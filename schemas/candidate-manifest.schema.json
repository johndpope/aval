{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rendered-motion.dev/schemas/candidate-manifest.schema.json",
  "title": "Rendered Motion immutable candidate manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "manifestKind", "releaseVersion", "releaseSetDigest", "commit", "tree", "cleanTree", "createdAt", "tools", "browserPin", "artifacts"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "manifestKind": { "const": "candidate" },
    "releaseVersion": { "const": "1.0.0" },
    "releaseSetDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "commit": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
    "tree": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
    "cleanTree": { "const": true },
    "createdAt": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$" },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "npm", "typescript", "vitest", "playwright", "apiExtractor"],
      "properties": {
        "node": { "$ref": "#/$defs/semanticVersion" },
        "npm": { "$ref": "#/$defs/semanticVersion" },
        "typescript": { "$ref": "#/$defs/semanticVersion" },
        "vitest": { "$ref": "#/$defs/semanticVersion" },
        "playwright": { "$ref": "#/$defs/semanticVersion" },
        "apiExtractor": { "$ref": "#/$defs/semanticVersion" }
      }
    },
    "browserPin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["playwrightBrowserManifestSha256", "browsers"],
      "properties": {
        "playwrightBrowserManifestSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "browsers": {
          "type": "object",
          "additionalProperties": false,
          "required": ["chromium", "firefox", "webkit"],
          "properties": {
            "chromium": { "$ref": "#/$defs/browser" },
            "firefox": { "$ref": "#/$defs/browser" },
            "webkit": { "$ref": "#/$defs/browser" }
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "path", "sha256", "byteLength", "mediaType"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$" },
          "role": { "enum": ["package", "package-index", "package-inspection", "sbom", "api-report", "schema", "fixture", "documentation", "example", "browser-harness", "release-policy", "legal-review", "license-report", "candidate-layout", "project-metadata"] },
          "path": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!/)(?!.*(?:^|/)(?:\\.|\\.\\.)(?:/|$))(?!.*//)[^?\\\\]+$" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "byteLength": { "type": "integer", "minimum": 0, "maximum": 1073741824 },
          "mediaType": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9!#$&^_.+-]{0,63}/[a-z0-9][a-z0-9!#$&^_.+-]{0,63}$" }
        }
      }
    }
  },
  "$defs": {
    "semanticVersion": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$" },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "engineVersion"],
      "properties": {
        "revision": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)$" },
        "engineVersion": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)(?:\\.(?:0|[1-9][0-9A-Za-z-]*)){1,3}$" }
      }
    }
  }
}
