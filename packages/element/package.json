{
  "name": "@rendered-motion/element",
  "version": "1.0.0",
  "description": "Progressive web component for interactive rendered motion assets.",
  "keywords": ["animation", "web-component", "accessibility", "motion"],
  "private": false,
  "type": "module",
  "sideEffects": [
    "./dist/auto.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "THIRD_PARTY_NOTICES.md"],
  "license": "MIT",
  "engines": { "node": ">=22.12.0" },
  "dependencies": {
    "@rendered-motion/player-web": "1.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.release.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  }
}
