{
  "name": "@rendered-motion/player-web",
  "version": "1.0.0",
  "description": "Web decoder, scheduler, and presentation runtime for rendered motion assets.",
  "keywords": ["animation", "webcodecs", "webgl", "motion"],
  "private": false,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "THIRD_PARTY_NOTICES.md"],
  "license": "MIT",
  "engines": { "node": ">=22.12.0" },
  "dependencies": {
    "@rendered-motion/format": "1.0.0",
    "@rendered-motion/graph": "1.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.release.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json"
  }
}
